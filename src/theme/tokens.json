{
  "$meta": {
    "name": "AETHER reference theme",
    "source": "reference dashboard screenshot (Hello Moni / AETHER)",
    "note": "Hex values matched from the reference image. Where a color was translucent or low-resolution, the nearest solid hex is provided."
  },
  "surface": {
    "bg":            "#F4F3F5",
    "surface":       "#FFFFFF",
    "surfaceMuted":  "#FAFAFB"
  },
  "ink": {
    "primary":   "#15151A",
    "soft":      "#4A4A52",
    "muted":     "#9A9AA2",
    "hairline":  "#ECEBEF",
    "rowHover":  "#F7F6F9"
  },
  "kpi": {
    "cream": { "gradientStart": "#FBF4DC", "gradientEnd": "#FAEFC6" },
    "blue":  { "gradientStart": "#E8EFFC", "gradientEnd": "#D8E5FB" },
    "lav":   { "gradientStart": "#F0EAFB", "gradientEnd": "#E6DBF7" },
    "rose":  { "gradientStart": "#FBE7EF", "gradientEnd": "#F6D9E6" },
    "valueText":  "#15151A",
    "labelText":  "#4A4A52"
  },
  "arrowButton": {
    "bg":       "#15151A",
    "bgHover":  "#2A2A30",
    "icon":     "#FFFFFF",
    "size":     "40px",
    "shadow":   "0 4px 12px rgba(20,20,30,0.18)"
  },
  "chart": {
    "bar":        "#8E7CF0",
    "barSoft":    "#C9C0F5",
    "grid":       "#ECEBEF",
    "axisText":   "#9A9AA2",
    "barRadius":  6,
    "barCategoryGap": "35%",
    "accentBlue": "#4070E0"
  },
  "table": {
    "headerBg":   "#FAFAFB",
    "headerText": "#9A9AA2",
    "rowBg":      "#FFFFFF",
    "rowHover":   "#F7F6F9",
    "divider":    "#EFEEF1"
  },
  "status": {
    "success":     { "fg": "#16A36B", "bg": "#E4F6EE" },
    "warning":     { "fg": "#C98A1E", "bg": "#FBF1DE" },
    "fail":        { "fg": "#E5484D", "bg": "#FCEAEA" },
    "criticalLow": { "fg": "#B00020", "bg": "#FBE3E6" }
  },
  "type": {
    "fontFamily": "\"Plus Jakarta Sans\", Inter, system-ui, sans-serif",
    "kpiValue":   { "size": "36px", "weight": 800, "tracking": "-0.02em" },
    "kpiLabel":   { "size": "14px", "weight": 600 },
    "heading":    { "size": "22px", "weight": 800 },
    "tableHeader":{ "size": "11px", "weight": 700, "case": "uppercase", "tracking": "0.08em" },
    "tableBody":  { "size": "14px", "weight": 500 },
    "chartAxis":  { "size": "11px", "weight": 500 }
  },
  "radius": { "card": "24px", "chip": "999px" },
  "shadow": {
    "card":  "0 1px 2px rgba(20,20,30,0.04), 0 8px 24px rgba(20,20,30,0.05)",
    "arrow": "0 4px 12px rgba(20,20,30,0.18)"
  }
}
