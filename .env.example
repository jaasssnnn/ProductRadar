# ─── Stripe Connect OAuth ────────────────────────────────────────────────────
# Your Stripe Connect platform client ID.
# Get it from: Stripe Dashboard → Settings → Connect → Get started
# Format: ca_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id_here

# Your Stripe secret key (NEVER expose to the client).
# Get it from: Stripe Dashboard → Developers → API keys → Secret key
# Use sk_test_... for testing, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# ─── App URL ─────────────────────────────────────────────────────────────────
# The base URL of your deployed app (no trailing slash).
# Locally: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Token Storage (choose one — see src/lib/tokenStore.js for instructions) ─

# Option A: Vercel KV (add a KV store in your Vercel project dashboard)
# These are set automatically by Vercel when you connect a KV store.
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=your_kv_token

# Option B: Vercel Postgres (add a Postgres store in your Vercel project dashboard)
# DATABASE_URL=postgresql://...

# ─── Groq AI (optional — app falls back to mock if missing) ──────────────────
# Get it from: https://console.groq.com
VITE_GROQ_API_KEY=gsk_your_groq_key_here
VITE_USE_MOCK_AI=false
